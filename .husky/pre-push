#!/bin/sh

echo "🔍 Q Pre-Push Guard — checking for known issues..."
ERRORS=0

# ── 1. Build check ──────────────────────────────────────────
echo "  → Running vite build..."
BUILD_OUTPUT=$(npx vite build 2>&1)
if [ $? -ne 0 ]; then
  echo "  ❌ BUILD FAILED"
  echo "$BUILD_OUTPUT" | tail -10
  ERRORS=$((ERRORS + 1))
else
  echo "  ✅ Build passed"
fi

# ── 2. Check for untracked files that are imported ──────────
echo "  → Checking for missing files..."
UNTRACKED=$(git ls-files --others --exclude-standard -- 'src/**/*.jsx' 'src/**/*.js' 'src/**/*.ts' 'src/**/*.tsx')
if [ -n "$UNTRACKED" ]; then
  for FILE in $UNTRACKED; do
    BASENAME=$(basename "$FILE" | sed 's/\.[^.]*$//')
    IMPORTER=$(git ls-files -- 'src/**/*.jsx' 'src/**/*.js' | xargs grep -l "from.*['\"].*${BASENAME}['\"]" 2>/dev/null | head -1)
    if [ -n "$IMPORTER" ]; then
      echo "  ❌ UNTRACKED FILE imported: $FILE (used by $IMPORTER)"
      echo "     Run: git add $FILE"
      ERRORS=$((ERRORS + 1))
    fi
  done
fi
if [ $ERRORS -eq 0 ]; then
  echo "  ✅ No missing imports"
fi

# ── 3. Check staged/changed files for 100vw ────────────────
echo "  → Checking changed files for 100vw..."
CHANGED=$(git diff --name-only HEAD@{upstream}..HEAD 2>/dev/null || git diff --name-only HEAD~1 2>/dev/null)
VW_HIT=0
for F in $CHANGED; do
  if [ -f "$F" ] && echo "$F" | grep -qE '\.(jsx|js|css)$'; then
    if grep -q "100vw" "$F" 2>/dev/null; then
      # Allow in mobile components and landing page (legitimate full-width usage)
      if ! echo "$F" | grep -qiE 'mobile|landing|login'; then
        echo "  ⚠️  100vw found in $F (may cause horizontal overflow)"
        VW_HIT=1
      fi
    fi
  fi
done
if [ $VW_HIT -eq 0 ]; then
  echo "  ✅ No 100vw issues in changed files"
fi

# ── 4. Block manualChunks in vite.config (causes TDZ crashes) ──
echo "  → Checking for manualChunks..."
if grep -v '^\s*//' vite.config.js 2>/dev/null | grep -q "manualChunks"; then
  echo "  ❌ manualChunks found in vite.config.js"
  echo "     This WILL cause 'Cannot access X before initialization' crashes in production."
  echo "     Remove manualChunks — React.lazy() handles code splitting."
  ERRORS=$((ERRORS + 1))
else
  echo "  ✅ No manualChunks (TDZ-safe)"
fi

# ── 5. Verify production chunks load without TDZ errors ────
echo "  → Validating chunk imports..."
TDZ_ERRORS=0
for CHUNK in dist/assets/*.js; do
  # Check each chunk can be parsed by Node (catches syntax/import order issues)
  # Extract static imports and verify they don't create circular init deps
  IMPORTS=$(grep -c "^import " "$CHUNK" 2>/dev/null || echo 0)
  SELF_REF=$(basename "$CHUNK" .js | sed 's/-[A-Za-z0-9]*$//')
  # Check if any chunk imports from itself (circular)
  if grep -q "from.*\\./${SELF_REF}-" "$CHUNK" 2>/dev/null; then
    echo "  ❌ Circular import in $CHUNK"
    TDZ_ERRORS=$((TDZ_ERRORS + 1))
  fi
done
if [ $TDZ_ERRORS -gt 0 ]; then
  echo "  ❌ $TDZ_ERRORS chunk(s) have circular imports — will crash in production"
  ERRORS=$((ERRORS + $TDZ_ERRORS))
else
  echo "  ✅ No circular chunk imports"
fi

# ── 6. Check for hardcoded secret values ───────────────────
echo "  → Checking for secrets..."
SECRET_HIT=$(grep -rn "sk_live_[A-Za-z0-9]\{10,\}\|sk_test_[A-Za-z0-9]\{10,\}\|eyJhbGciOiJ" --include="*.jsx" --include="*.js" src/ 2>/dev/null | grep -v node_modules | grep -v "test/\|\.test\." || true)
if [ -n "$SECRET_HIT" ]; then
  echo "  ❌ Possible hardcoded secrets:"
  echo "$SECRET_HIT" | while read line; do echo "     $line"; done
  ERRORS=$((ERRORS + 1))
else
  echo "  ✅ No secrets detected"
fi

# ── Result ──────────────────────────────────────────────────
echo ""
if [ $ERRORS -gt 0 ]; then
  echo "🚫 Push blocked — $ERRORS error(s) found. Fix and try again."
  exit 1
else
  echo "✅ All checks passed. Pushing..."
fi
