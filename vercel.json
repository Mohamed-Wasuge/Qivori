{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=(self)" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/ref/:code", "destination": "/?ref=:code" },
    { "source": "/((?!api/|assets/|google).*)", "destination": "/" }
  ],
  "crons": [
    { "path": "/api/lifecycle-cron", "schedule": "0 8 * * *" },
    { "path": "/api/onboarding-emails", "schedule": "0 14 * * *" },
    { "path": "/api/email-followup", "schedule": "0 15 * * *" },
    { "path": "/api/weekly-summary", "schedule": "0 15 * * 0" },
    { "path": "/api/agent-autonomous", "schedule": "0 9 * * *" },
    { "path": "/api/agent-daily-briefing", "schedule": "0 13 * * *" },
    { "path": "/api/agent-weekly-report", "schedule": "0 13 * * 1" },
    { "path": "/api/self-repair", "schedule": "0 6 * * *" },
    { "path": "/api/uptime-monitor", "schedule": "0 5 * * *" },
    { "path": "/api/demo-followup", "schedule": "0 10 * * *" },
    { "path": "/api/churn-alert", "schedule": "0 7 * * *" },
    { "path": "/api/dep-scanner", "schedule": "0 3 * * 0" },
    { "path": "/api/load-finder", "schedule": "0 8 * * *" },
    { "path": "/api/bot-load-finder", "schedule": "0 10 * * *" },
    { "path": "/api/carrier-expiry-alerts", "schedule": "0 8 * * 1" },
    { "path": "/api/check-calls", "schedule": "0 12 * * *" },
    { "path": "/api/check-call-scheduler", "schedule": "0 9 * * *" },
    { "path": "/api/admin-notifications?action=send_digest", "schedule": "0 18 * * *" },
    { "path": "/api/doc-expiry-alerts", "schedule": "0 8 * * *" },
    { "path": "/api/driver-alerts", "schedule": "0 9 * * *" },
    { "path": "/api/driver-weekly", "schedule": "0 10 * * 0" },
    { "path": "/api/contract-expiry-alerts", "schedule": "0 8 * * 1" },
    { "path": "/api/lane-history-cron", "schedule": "0 2 * * 1" },
    { "path": "/api/carrier-score", "schedule": "0 3 * * 0" },
    { "path": "/api/apply-referral-rewards", "schedule": "0 9 * * *" },
    { "path": "/api/health-monitor", "schedule": "0 4 * * *" },
    { "path": "/api/auto-rollback", "schedule": "0 4 * * *" },
    { "path": "/api/compliance-alerts-cron", "schedule": "0 13 * * *" }
  ]
}
